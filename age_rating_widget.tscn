[gd_scene load_steps=3 format=3 uid="uid://dwba6t8v00m8a"]

[sub_resource type="GDScript" id="GDScript_afpae"]
script/source = "# this script is licensed under MIT license:
# 	https://codeberg.org/sosasees/mit-license/raw/branch/no-year/LICENSE
# source:
# 	https://codeberg.org/sosasees/dars-generator
extends HBoxContainer


@export var rating_criteria: String = ''
@export_range(2, 6) var rating_options: int = 2


func _ready() -> void:
	get_node('Label').set_text( 'age-rating-criteria_' +
		rating_criteria.replace(' ', '-')
	)
	get_node('OptionButton').age_rating_criteria = rating_criteria
	get_node('OptionButton').rating_options = rating_options


func _on_file_opened() -> void:
	get_node('OptionButton')._select_int(FileManager.get_value(
		'age_rating_criteria', rating_criteria.replace(' ', '_')
	))
"

[sub_resource type="GDScript" id="GDScript_6y20w"]
script/source = "# this script is licensed under MIT license:
# 	https://codeberg.org/sosasees/mit-license/raw/branch/no-year/LICENSE
# source:
# 	https://codeberg.org/sosasees/dars-generator
extends OptionButton


var age_rating_criteria: String = ''
var rating_options: int


func _ready() -> void:
	get_popup().set_theme_type_variation('PopupMenu_Window')


func _on_widget_ready() -> void:
	for i in rating_options:
		add_item( 'age-rating-criteria_' +
			age_rating_criteria.replace(' ', '-') + '_' +
			String.num_int64(i), i
		)


func _on_item_selected(index: int) -> void:
	FileManager.set_value( 'age_rating_criteria',
		age_rating_criteria.replace(' ', '_'), index
	)
"

[node name="AgeRatingWidget" type="HBoxContainer"]
script = SubResource("GDScript_afpae")

[node name="Label" type="Label" parent="."]
layout_mode = 2
size_flags_horizontal = 3
theme_type_variation = &"Label_Window_OnSurface"
horizontal_alignment = 2

[node name="OptionButton" type="OptionButton" parent="."]
layout_mode = 2
size_flags_horizontal = 3
theme_type_variation = &"OptionButton_Window_OnSurface"
script = SubResource("GDScript_6y20w")

[connection signal="ready" from="." to="OptionButton" method="_on_widget_ready"]
[connection signal="item_selected" from="OptionButton" to="OptionButton" method="_on_item_selected"]
