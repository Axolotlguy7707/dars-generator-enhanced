[sub_resource type="GDScript" id="GDScript_pmpfq"]
script/source = "# this script is licensed under MIT license:
# 	https://codeberg.org/sosasees/mit-license/raw/branch/no-year/LICENSE
# source:
# 	https://codeberg.org/sosasees/dars-generator
extends Label


func _ready() -> void:
	var dars_version: Dictionary = ProjectSettings.get_setting(
		'application/config/version/dars'
	)
	var app_version: Dictionary = ProjectSettings.get_setting(
		'application/config/version/app'
	)
	
	set_text( 'v' + String.num_int64(dars_version['year']) )
	if not dars_version['revision'] == 0:
		set_text( get_text() + '.' +
			String.num_int64(dars_version['revision'])
		)
	#if not dars_version['status'] == 'stable':
	#	set_text( get_text() + '.' + dars_version['status'] )
	#set_text( get_text() + '.' +
	#	String.num_int64(app_version['revision'])
	#)
	if not app_version['status'] == 'stable':
		set_text(get_text() + '.' + app_version['status'])
"

