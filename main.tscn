extends Control


signal file_opened


func _ready() -> void:
	set_visible(false)


func _on_show_button_pressed() -> void:
	set_visible(true)


func _on_open_dialog_file_selected(path: String) -> void:
	FileManager.open_file(path)
	file_opened.emit()
	get_node('%WindowTitle').set_screen_name(path)
	set_visible(true)
"

