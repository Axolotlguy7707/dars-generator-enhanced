[sub_resource type="GDScript" id="GDScript_ni72u"]
script/source = "# this script is licensed under MIT license:
# 	https://codeberg.org/sosasees/mit-license/raw/branch/no-year/LICENSE
# source:
# 	https://codeberg.org/sosasees/dars-generator
extends Node


func _ready() -> void:
	set_screen_name('main menu')


@warning_ignore('shadowed_variable_base_class')
func set_screen_name(name: String) -> void:
	get_tree().get_root().set_title( name + ' — ' +
		ProjectSettings.get_setting('application/config/name')
	)
"

[sub_resource type="GDScript" id="GDScript_ra2wt"]
script/source = "# this script is licensed under MIT license:
# 	https://codeberg.org/sosasees/mit-license/raw/branch/no-year/LICENSE
# source:
# 	https://codeberg.org/sosasees/dars-generator
extends PanelContainer
class_name themes


@export_group('Themes', 'theme_')
@export var theme_green: Theme
@export var theme_yellow: Theme
@export var theme_red: Theme

func _process(delta):
	var focused = get_viewport().gui_get_focus_owner()
	var typing = focused is LineEdit or focused is TextEdit
	
	if typing:
		return
	
	if Input.is_action_just_pressed(\"themeGreen\"):
		theme = theme_green
	if Input.is_action_just_pressed(\"themeYellow\"):
		theme = theme_yellow
	if Input.is_action_just_pressed(\"themeRed\"):
		theme = theme_red
"

