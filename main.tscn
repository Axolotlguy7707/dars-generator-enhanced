[sub_resource type="GDScript" id="GDScript_4eqff"]
script/source = "extends SubViewport


func _on_save_dialog_webp_file_selected(path: String) -> void:
	var image: Image = get_texture().get_image()
	image.crop(
		image.get_used_rect().size.x,
		image.get_used_rect().size.y
	)
	image.save_webp(path)


func _on_save_dialog_png_file_selected(path: String) -> void:
	var image: Image = get_texture().get_image()
	image.crop(
		image.get_used_rect().size.x,
		image.get_used_rect().size.y
	)
	image.save_png(path)
"

[sub_resource type="GDScript" id="GDScript_f4mpu"]
script/source = "# this script is licensed under MIT license:
# 	https://codeberg.org/sosasees/mit-license/raw/branch/no-year/LICENSE
# source:
# 	https://codeberg.org/sosasees/dars-generator
extends Button


func _on_save_dialog_file_selected(path: String) -> void:
	var file_text = ( '## ' + tr('markdown-text_age-rating-header') +
		'\\n\\n> ' + String.num_int64(BadgeInfo.get_age_rating()) + '\\n\\n' +
		BadgeInfo.get_age_rating_text(true) + '\\n\\n' +
		BadgeInfo.get_content_descriptors_list('- ')
	)
	file_text = file_text.strip_edges()
	file_text += '\\n'
	
	var file: FileAccess = FileAccess.open(path, FileAccess.WRITE)
	file.store_string(file_text)
	file.close()
"

